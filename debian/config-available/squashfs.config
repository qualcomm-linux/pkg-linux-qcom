# Qualcomm packaging: SQUASHFS options required for Ubuntu compatibility.
# Applied as a config fragment during override_dh_auto_configure in debian/rules,
# after the base defconfig and qcom.config have been merged.
#
# This fragment supersedes debian/scripts/enable-squashfs-configs.sh.
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_XZ=y
CONFIG_SQUASHFS_LZO=y
CONFIG_SQUASHFS_XATTR=y
CONFIG_SQUASHFS_ZLIB=y
CONFIG_SQUASHFS_LZ4=y
