#!/usr/bin/make -f
.ONESHELL:
SHELL := /bin/bash
.SHELLFLAGS := -e -o pipefail -c

# Include dpkg package info only after 'prepare' has substituted @KVER@ in
# debian/changelog. If the file still contains the template placeholder,
# dpkg-parsechangelog would emit confusing warnings — skip the include instead.
ifneq ($(wildcard debian/changelog),)
ifeq ($(shell grep -qF '@KVER@' debian/changelog 2>/dev/null && echo template || echo ready),ready)
include /usr/share/dpkg/pkg-info.mk
export DEB_VERSION
endif
endif

export DH_VERBOSE ?= 1
export ARCH = arm64

# Optional out-of-tree build directory (honor either O or KBUILD_OUTPUT)
# If set, we'll pass O=<dir> to make and read artifacts from that objdir.
BUILD_OBJ ?= $(or $(O),$(KBUILD_OUTPUT))

# Make argument that is empty when BUILD_OBJ is empty (so we don't pass a dangling "O=")
KBUILD_O_ARG := $(if $(BUILD_OBJ),O=$(BUILD_OBJ),)

# Parallel jobs (override with DEB_BUILD_OPTIONS=parallel=N if desired)
PARALLEL ?= $(shell nproc)

# objcopy for debug symbol extraction (cross-compile aware).
# Prefer the aarch64 cross-compiler's objcopy; fall back to the host objcopy.
OBJCOPY ?= $(shell which aarch64-linux-gnu-objcopy 2>/dev/null || which objcopy 2>/dev/null || echo objcopy)


# dkms identifies architectures in uname -m vocabulary (aarch64), unlike the
# kbuild ARCH token above (arm64). The distinction matters for dkms.conf
# BUILD_EXCLUSIVE_ARCH gates, which match against this value.
DKMS_ARCH ?= aarch64

# File that caches the kernelrelease (BASE, i.e., uname -r)
KREL_FILE := debian/kernel.release

%:
	dh $@ --buildsystem=makefile

# ---------------------------------------------------------------------------
# prepare: generate debian/control and debian/changelog from *.in templates.
#
# This target must be called before dpkg-buildpackage / sbuild, since those
# tools read debian/control before invoking any debian/rules targets.
#
# Usage:
#   make -f debian/rules prepare KVER=<kernelrelease>
#   make -f debian/rules prepare LOCALVERSION=<suffix> [KVER_EXTRA=<tag>]
#
# KVER is the full kernelrelease string (uname -r), e.g.:
#   6.12.0-qcom-next-20260210
#
# LOCALVERSION is the suffix appended to the base kernel version when KVER
# is not provided explicitly, e.g.: -qcom-next-20260210
#
# KVER_EXTRA is an optional additional suffix appended to the final KVER,
# useful for distinguishing local builds, CI runs, or user modifications
# without changing the kernel source, e.g.:
#   KVER_EXTRA=-mybuild  →  7.0.0-rc2-qcom-next-20260312-mybuild
#   KVER_EXTRA=-ci42     →  7.0.0-rc2-qcom-next-20260312-ci42
# KVER_EXTRA is appended after LOCALVERSION (or after KVER if explicit).
#
# The generated debian/control and debian/changelog are gitignored; only the
# *.in templates are version-controlled.
# ---------------------------------------------------------------------------
KVER_EXTRA ?=
DISTRO     ?= unstable

.PHONY: prepare
prepare:
	@# Replicate the kernelrelease formula (VERSION.PATCHLEVEL.SUBLEVEL +
	@# EXTRAVERSION + localversion* files + LOCALVERSION + KVER_EXTRA) without
	@# invoking 'make kernelrelease', which requires a configured tree (.config).
	@# prepare must run before the kernel build, so we read the Makefile directly.
	@set -e; \
	if [ -n "$(KVER)" ]; then \
		KVER_RESOLVED="$(KVER)"; \
	else \
		echo "KVER not set — reading base version from kernel Makefile..."; \
		VER=$$(grep '^VERSION = ' Makefile | awk '{print $$3}'); \
		PATCH=$$(grep '^PATCHLEVEL = ' Makefile | awk '{print $$3}'); \
		SUB=$$(grep '^SUBLEVEL = ' Makefile | awk '{print $$3}'); \
		EXTRA=$$(grep '^EXTRAVERSION = ' Makefile | awk '{print $$3}' || true); \
		TREE_LOCALVER=$$(cat localversion* 2>/dev/null | tr -d '\n' || true); \
		BASE_KVER="$${VER}.$${PATCH}.$${SUB}$${EXTRA}$${TREE_LOCALVER}"; \
		KVER_RESOLVED="$${BASE_KVER}$(LOCALVERSION)"; \
		echo "Auto-detected KVER=$$KVER_RESOLVED (base=$$BASE_KVER, LOCALVERSION=$(LOCALVERSION))"; \
	fi; \
	if [ -n "$(KVER_EXTRA)" ]; then \
		KVER_RESOLVED="$${KVER_RESOLVED}$(KVER_EXTRA)"; \
		echo "Appending KVER_EXTRA=$(KVER_EXTRA) → KVER=$$KVER_RESOLVED"; \
	fi; \
	if [ -z "$$KVER_RESOLVED" ]; then \
		echo "ERROR: Could not determine KVER. Pass KVER=<kernelrelease> or LOCALVERSION=<suffix>."; \
		exit 1; \
	fi; \
	sed "s/@KVER@/$$KVER_RESOLVED/g" debian/control.in > debian/control; \
	sed "s/@KVER@/$$KVER_RESOLVED/g; s/@DISTRO@/$(DISTRO)/g" debian/changelog.in > debian/changelog; \
	echo "Generated debian/control and debian/changelog for KVER=$$KVER_RESOLVED DISTRO=$(DISTRO)"

override_dh_auto_configure:
	# ---------------------------------------------------------------------------
	# Config build order:
	#   1. ARM64 base defconfig
	#   2. Disable CONFIG_LOCALVERSION_AUTO (must happen before any merges)
	#   3. Config fragments — applied in a single unified pipeline:
	#        a. arch/arm64/configs/qcom.config   (kernel-source fragment, if present)
	#        b. arch/arm64/configs/prune.config  (kernel-source fragment, if present)
	#        c. debian/config/*.config            (packaging fragments, sorted order)
	#      All fragments use the same mechanism: append to .config + olddefconfig.
	#   4. Re-check CONFIG_LOCALVERSION_AUTO (merges may re-enable it)
	#   5. arch/arm64/configs/debug.config — only when DEB_BUILD_PROFILES=debug
	# ---------------------------------------------------------------------------

	# Step 1: Base defconfig
	$(MAKE) $(KBUILD_O_ARG) ARCH=$(ARCH) defconfig

	# Step 2: Disable CONFIG_LOCALVERSION_AUTO to prevent git hash in version.
	# Must be done after defconfig and before any config merges.
	@CONFIG_FILE="$(if $(BUILD_OBJ),$(BUILD_OBJ)/).config"; \
	if [ -f "$$CONFIG_FILE" ]; then \
		echo "Disabling CONFIG_LOCALVERSION_AUTO in $$CONFIG_FILE"; \
		sed -i '/^CONFIG_LOCALVERSION_AUTO/d' "$$CONFIG_FILE"; \
		echo "# CONFIG_LOCALVERSION_AUTO is not set" >> "$$CONFIG_FILE"; \
		echo "CONFIG_LOCALVERSION_AUTO disabled"; \
	else \
		echo "ERROR: .config not found at $$CONFIG_FILE"; \
		exit 1; \
	fi

	# Step 3: Unified config fragment pipeline.
	# Fragments are collected in order and applied together:
	#   - arch/arm64/configs/qcom.config first (kernel-source, present in qcom-next)
	#   - arch/arm64/configs/prune.config second (kernel-source, prunes qcom.config options)
	#   - then debian/config/*.config in sorted order (packaging repo fragments)
	# All are applied via: append to .config → make olddefconfig.
	# To add options: drop a *.config file in debian/config/ — no rules changes needed.
	@CONFIG_FILE="$(if $(BUILD_OBJ),$(BUILD_OBJ)/).config"; \
	FRAGMENTS=""; \
	if [ -f arch/arm64/configs/qcom.config ]; then \
		echo "Found kernel-source fragment: arch/arm64/configs/qcom.config"; \
		FRAGMENTS="arch/arm64/configs/qcom.config"; \
	else \
		echo "Note: arch/arm64/configs/qcom.config not found (not a qcom-next tree?)"; \
	fi; \
	if [ -f arch/arm64/configs/prune.config ]; then \
		echo "Found kernel-source fragment: arch/arm64/configs/prune.config"; \
		FRAGMENTS="$$FRAGMENTS arch/arm64/configs/prune.config"; \
	else \
		echo "Note: arch/arm64/configs/prune.config not found (skipping)"; \
	fi; \
	if [ -d debian/config ] && ls debian/config/*.config >/dev/null 2>&1; then \
		for f in $$(ls debian/config/*.config | sort); do \
			echo "Found packaging fragment: $$f"; \
			FRAGMENTS="$$FRAGMENTS $$f"; \
		done; \
	fi; \
	if [ -n "$$FRAGMENTS" ]; then \
		for frag in $$FRAGMENTS; do \
			echo "Applying config fragment: $$frag"; \
			cat "$$frag" >> "$$CONFIG_FILE"; \
		done; \
		echo "Running olddefconfig to resolve all fragment conflicts..."; \
		$(MAKE) $(KBUILD_O_ARG) ARCH=$(ARCH) olddefconfig; \
	else \
		echo "No config fragments to apply"; \
	fi

	# Step 4: Re-check CONFIG_LOCALVERSION_AUTO — merges may have re-enabled it.
	@CONFIG_FILE="$(if $(BUILD_OBJ),$(BUILD_OBJ)/).config"; \
	if grep -q "^CONFIG_LOCALVERSION_AUTO=y" "$$CONFIG_FILE" 2>/dev/null; then \
		echo "Re-disabling CONFIG_LOCALVERSION_AUTO (was re-enabled by a config merge)"; \
		sed -i '/^CONFIG_LOCALVERSION_AUTO/d' "$$CONFIG_FILE"; \
		echo "# CONFIG_LOCALVERSION_AUTO is not set" >> "$$CONFIG_FILE"; \
	fi

	# Step 5: Merge debug.config if debug build profile is active.
	@if echo "$(DEB_BUILD_PROFILES)" | grep -qw "debug"; then \
		if [ -f arch/arm64/configs/debug.config ]; then \
			echo "Debug profile active: merging arch/arm64/configs/debug.config..."; \
			$(MAKE) $(KBUILD_O_ARG) ARCH=$(ARCH) debug.config; \
		else \
			echo "Warning: debug profile requested but arch/arm64/configs/debug.config not found"; \
		fi; \
	fi

override_dh_auto_build:
	@CHANGELOG_PKG=$$(head -n1 debian/changelog | cut -d' ' -f1); \
	# Back-derive LOCALVER_SUFFIX from the package name: strip everything the
	# kernel produces on its own (kernelversion + tree localversion* files) to
	# recover only the user-provided suffix, then pass it as LOCALVERSION= to
	# make so that kernelrelease matches the package name exactly.
	BASE_KVER=$$($(MAKE) $(KBUILD_O_ARG) ARCH=$(ARCH) -s kernelversion); \
	TREE_LOCALVER=$$(cat localversion* 2>/dev/null | tr -d '\n' || true); \
	LOCALVER_SUFFIX=$$(echo "$$CHANGELOG_PKG" | sed "s/linux-image-$$BASE_KVER$$TREE_LOCALVER//" | sed 's/-qcom$$//'); \
	echo "Building with LOCALVERSION=$$LOCALVER_SUFFIX"; \
	$(MAKE) $(KBUILD_O_ARG) ARCH=$(ARCH) LOCALVERSION=$$LOCALVER_SUFFIX -j$(PARALLEL) Image; \
	$(MAKE) $(KBUILD_O_ARG) ARCH=$(ARCH) LOCALVERSION=$$LOCALVER_SUFFIX -j$(PARALLEL) modules; \
	$(MAKE) $(KBUILD_O_ARG) ARCH=$(ARCH) LOCALVERSION=$$LOCALVER_SUFFIX -j$(PARALLEL) dtbs || true; \
	mkdir -p $(dir $(KREL_FILE)); \
	KREL=$$( $(MAKE) $(KBUILD_O_ARG) ARCH=$(ARCH) LOCALVERSION=$$LOCALVER_SUFFIX -s kernelrelease 2>&1 | grep -E '^[0-9]+\.' | head -n1 ); \
	printf "%s\n" "$$KREL" > "$(KREL_FILE)"; \
	echo "Detected BASE kernel release: $$KREL"

override_dh_auto_install:
	@BASE=$$(cat $(KREL_FILE)); \
	echo "Installing for BASE kernel release: $$BASE"; \
	CHANGELOG_PKG=$$(head -n1 debian/changelog | cut -d' ' -f1); \
	echo "Package name from changelog: $$CHANGELOG_PKG"; \
	PKG=debian/$$CHANGELOG_PKG; \
	HDR_PKG=debian/$$(echo "$$CHANGELOG_PKG" | sed 's/^linux-image-/linux-headers-/'); \
	DBG_PKG=debian/$$(echo "$$CHANGELOG_PKG")-dbg; \
	\
	# Resolve object dir (if any)
	OBJ_DIR="$(BUILD_OBJ)"; \
	IMG_DIR="arch/arm64/boot"; \
	DTB_ROOT="arch/arm64/boot/dts/"; \
	if [ -n "$$OBJ_DIR" ]; then \
		IMG_DIR="$$OBJ_DIR/$$IMG_DIR"; \
		DTB_ROOT="$$OBJ_DIR/$$DTB_ROOT"; \
	fi; \
	\
	# Pick the first available kernel image: Image, Image.gz, or Image.lz4
	IMG_PATH=""; \
	for cand in "$$IMG_DIR/Image" "$$IMG_DIR/Image.gz" "$$IMG_DIR/Image.lz4"; do \
		if [ -f "$$cand" ]; then IMG_PATH="$$cand"; break; fi; \
	done; \
	[ -n "$$IMG_PATH" ] || { echo "ERROR: No kernel image found under $$IMG_DIR (tried Image, Image.gz, Image.lz4)"; exit 1; }; \
	[ -d "$$DTB_ROOT" ] || { echo "ERROR: Missing DTB root at $$DTB_ROOT"; exit 1; }; \
	\
	# Locate the active .config (objdir-aware)
	CFG_PATH=".config"; \
	[ -n "$$OBJ_DIR" ] && CFG_PATH="$$OBJ_DIR/.config"; \
	[ -f "$$CFG_PATH" ] || { echo "ERROR: Missing .config at $$CFG_PATH"; exit 1; }; \
	\
	# /boot artifacts (always install as vmlinuz-<BASE>)
	# (avoid 'install -D' parsing quirks by creating dirs and copying explicitly)
	mkdir -p "$$PKG/boot"; \
	cp -a -T "$$IMG_PATH" "$$PKG/boot/vmlinuz-$$BASE"; \
	cp -a -T "$$CFG_PATH" "$$PKG/boot/config-$$BASE"; \
	\
	# Modules (strip like your original packaging script)
	$(MAKE) $(KBUILD_O_ARG) ARCH=$(ARCH) modules_install \
		INSTALL_MOD_PATH=$$PKG INSTALL_MOD_STRIP=1; \
	\
	# Fix build/source symlinks: modules_install sets them to the build machine's
	# absolute source tree path, which is a broken symlink on the target system.
	# Repoint both to the installed headers location so that out-of-tree module
	# builds (DKMS, etc.) work correctly after linux-headers-<BASE>-qcom is installed.
	rm -f $$PKG/lib/modules/$$BASE/build; \
	rm -f $$PKG/lib/modules/$$BASE/source; \
	ln -sf /usr/src/linux-headers-$$BASE $$PKG/lib/modules/$$BASE/build; \
	ln -sf /usr/src/linux-headers-$$BASE $$PKG/lib/modules/$$BASE/source; \
	\
	# ALL DTBs recursively (preserve vendor subdirs), only *.dtb
	# Install to standard Debian location: /usr/lib/linux-image-<BASE>/
	mkdir -p $$PKG/usr/lib/linux-image-$$BASE; \
	rsync -a --prune-empty-dirs \
	      --include='*/' --include='*.dtb' --include='*.dtbo' --exclude='*' \
	      "$$DTB_ROOT" $$PKG/usr/lib/linux-image-$$BASE/; \
	\
	# Ubuntu compatibility: /lib/firmware/<KVER>/device-tree/
	# Ubuntu's flash-kernel expects DTBs at /lib/firmware/<KVER>/device-tree/;
	# Debian installs them to /usr/lib/linux-image-<KVER>/. A single relative
	# directory symlink satisfies both without duplicating DTB binaries.
	#
	# The symlink is placed under usr/lib/firmware/ so the relative target
	# ../../linux-image-<KVER> resolves correctly on both classic and usrmerge
	# systems (/lib -> usr/lib):
	#
	#   /usr/lib/firmware/<KVER>/device-tree -> ../../linux-image-<KVER>
	#   resolves to: /usr/lib/linux-image-<KVER>  ✓
	#
	# On usrmerge systems the symlink is also reachable via /lib/firmware/<KVER>/
	# as flash-kernel expects.
	#
	# Both the symlink and its target reside under usr/ (same top-level directory),
	# so Debian Policy §10.5 mandates a relative symlink and dh_link will NOT
	# convert it to absolute — no need to defer this past dh_link.
	mkdir -p $$PKG/usr/lib/firmware/$$BASE; \
	ln -sfT ../../linux-image-$$BASE $$PKG/usr/lib/firmware/$$BASE/device-tree; \
	\
	# Install kernel headers for linux-headers-<BASE>-qcom package.
	# Follows the upstream install-extmod-build approach (scripts/package/install-extmod-build):
	#   Pass 1 (source tree): Makefile, include/, scripts/, arch/arm64/ headers
	#   Pass 2 (build dir):   generated headers, compiled scripts, Module.symvers, .config
	#
	# Note: make headers_install (UAPI headers) is intentionally NOT run here.
	# Running it overwrites kernel-internal headers in include/ with their UAPI
	# counterparts. The critical corruption is include/asm-generic/bitsperlong.h:
	# the kernel-internal version defines BITS_PER_LONG via #ifdef CONFIG_64BIT,
	# while the UAPI version only defines __BITS_PER_LONG. This breaks every
	# DKMS and out-of-tree module build with 'BITS_PER_LONG undeclared', which
	# cascades into hundreds of further errors. UAPI headers are provided by
	# linux-libc-dev, not by the kernel headers package.
	HDRDIR="$$HDR_PKG/usr/src/linux-headers-$$BASE"; \
	echo "Installing kernel headers to $$HDRDIR"; \
	mkdir -p "$$HDRDIR"; \
	\
	# Pass 1: source-tree files needed for out-of-tree module builds.
	# include/ covers linux/, uapi/, asm-generic/, generated/ (in-tree builds).
	# scripts/ provides the build infrastructure (kconfig, basic, etc.).
	cp -a Makefile "$$HDRDIR/"; \
	cp -a include "$$HDRDIR/"; \
	cp -a scripts "$$HDRDIR/"; \
	mkdir -p "$$HDRDIR/arch/arm64"; \
	find arch/arm64 -maxdepth 1 -name 'Makefile*' \
	    -exec cp -a {} "$$HDRDIR/arch/arm64/" \; 2>/dev/null || true; \
	[ -d arch/arm64/include ] && cp -a arch/arm64/include "$$HDRDIR/arch/arm64/"; \
	\
	# Pass 2: build-directory generated files (overlay on source-tree files).
	# For out-of-tree builds (OBJ_DIR set), generated headers live in OBJ_DIR.
	# For in-tree builds they are already in the source tree (copied in Pass 1).
	if [ -n "$$OBJ_DIR" ]; then \
		[ -d "$$OBJ_DIR/include/generated" ] && \
		    cp -a "$$OBJ_DIR/include/generated" "$$HDRDIR/include/"; \
		if [ -d "$$OBJ_DIR/arch/arm64/include/generated" ]; then \
		    mkdir -p "$$HDRDIR/arch/arm64/include"; \
		    cp -a "$$OBJ_DIR/arch/arm64/include/generated" "$$HDRDIR/arch/arm64/include/"; \
		fi; \
		[ -d "$$OBJ_DIR/scripts" ] && cp -a "$$OBJ_DIR/scripts/." "$$HDRDIR/scripts/"; \
		cp -a "$$OBJ_DIR/Module.symvers" "$$HDRDIR/" 2>/dev/null || true; \
		cp -a "$$OBJ_DIR/.config" "$$HDRDIR/"; \
	else \
		cp -a Module.symvers "$$HDRDIR/" 2>/dev/null || true; \
		cp -a .config "$$HDRDIR/"; \
	fi; \
	\
	# module.lds — generated linker script needed for out-of-tree module builds.
	# It lives in the build directory; fall back to source tree for in-tree builds.
	mkdir -p "$$HDRDIR/arch/arm64/kernel"; \
	MODULE_LDS="arch/arm64/kernel/module.lds"; \
	[ -n "$$OBJ_DIR" ] && MODULE_LDS="$$OBJ_DIR/arch/arm64/kernel/module.lds"; \
	cp -a "$$MODULE_LDS" "$$HDRDIR/arch/arm64/kernel/" 2>/dev/null || true; \
	\
	# Install debug symbols for linux-image-<BASE>-qcom-dbg package.
	# Following the upstream kernel builddeb approach (scripts/package/builddeb):
	#   - objcopy --only-keep-debug extracts debug symbols from each .ko
	#   - Symbols go to /usr/lib/debug/lib/modules/<BASE>/ (NOT /lib/modules/)
	#   - No file conflicts with the main linux-image package
	#   - vmlinux installed for perf/crash/systemtap/kdump-tools
	echo "Installing debug symbols to $$DBG_PKG"; \
	\
	# Per-module debug symbol extraction via objcopy --only-keep-debug.
	# modules.order lists every built module (relative to the build root).
	MODULES_ORDER="modules.order"; \
	[ -n "$$OBJ_DIR" ] && MODULES_ORDER="$$OBJ_DIR/modules.order"; \
	if [ -f "$$MODULES_ORDER" ]; then \
		while IFS= read -r mod; do \
			mod="$${mod%.o}.ko"; \
			src_mod="$$mod"; \
			[ -n "$$OBJ_DIR" ] && src_mod="$$OBJ_DIR/$$mod"; \
			[ -f "$$src_mod" ] || continue; \
			dbg="$$DBG_PKG/usr/lib/debug/lib/modules/$$BASE/$$mod"; \
			mkdir -p "$${dbg%/*}"; \
			$(OBJCOPY) --only-keep-debug "$$src_mod" "$$dbg" 2>/dev/null || \
				cp -a "$$src_mod" "$$dbg"; \
		done < "$$MODULES_ORDER"; \
	else \
		echo "Warning: modules.order not found — skipping per-module debug symbol extraction"; \
	fi; \
	\
	# vmlinux — full unstripped image for perf, crash, systemtap, kdump-tools.
	# Layout mirrors the upstream builddeb script.
	VMLINUX_PATH="vmlinux"; \
	[ -n "$$OBJ_DIR" ] && VMLINUX_PATH="$$OBJ_DIR/vmlinux"; \
	if [ -f "$$VMLINUX_PATH" ]; then \
		mkdir -p $$DBG_PKG/usr/lib/debug/lib/modules/$$BASE; \
		cp -a $$VMLINUX_PATH $$DBG_PKG/usr/lib/debug/lib/modules/$$BASE/vmlinux; \
		mkdir -p $$DBG_PKG/usr/lib/debug/boot; \
		ln -sf ../lib/modules/$$BASE/vmlinux \
		       $$DBG_PKG/usr/lib/debug/boot/vmlinux-$$BASE; \
		ln -sf lib/modules/$$BASE/vmlinux \
		       $$DBG_PKG/usr/lib/debug/vmlinux-$$BASE; \
	else \
		echo "Warning: vmlinux not found at $$VMLINUX_PATH — debug package will not contain vmlinux"; \
	fi; \
	\
	# ── DKMS module integration ──────────────────────────────────────────────────
	# Delegated to debian/scripts/bundle-dkms-modules.sh.
	# The script reads debian/dkms-modules, builds each listed module against the
	# staging headers produced earlier in this same dpkg-buildpackage run, and
	# bundles the resulting .ko files into the linux-image and -dbg staging trees.
	# It can also be invoked directly by a developer — see the script's --help.
	$(CURDIR)/debian/scripts/bundle-dkms-modules.sh \
	    --kver            "$$BASE" \
	    --headers-dir     "$(CURDIR)/debian/linux-headers-$$BASE-qcom/usr/src/linux-headers-$$BASE" \
	    --image-pkg-dir   "$(CURDIR)/$$PKG" \
	    --dbg-pkg-dir     "$(CURDIR)/$$DBG_PKG" \
	    --arch            "$(DKMS_ARCH)" \
	    --objcopy         "$(OBJCOPY)" \
	    --modules-manifest "$(CURDIR)/debian/dkms-modules"

# Skip automatic dh_installmodules - we'll call it manually in override_dh_installdeb
override_dh_installmodules:
	@echo "Skipping automatic dh_installmodules (will be called manually)"

# Override dh_installdeb to handle versioned package names.
#
# dh_installmodules injects the depmod #DEBHELPER# snippet by looking for
# debian/<pkgname>.postinst. Since our package name is dynamic (linux-image-
# <kver>-qcom), we generate debian/<pkgname>.postinst directly from the
# postinst.in template here (using BASE from kernel.release) so that
# dh_installmodules finds and injects into our script rather than generating
# a fresh one that overwrites our run-parts hooks.
#
# We do NOT rely on a pre-generated debian/linux-image.postinst because
# dpkg-buildpackage calls debian/rules clean before the build, which would
# delete any file listed in debian/clean.
override_dh_installdeb:
	@BASE=$$(cat $(KREL_FILE)); \
	CHANGELOG_PKG=$$(head -n1 debian/changelog | cut -d' ' -f1); \
	\
	# Generate debian/<pkgname>.postinst from template with KVER substituted.
	# dh_installmodules will find this file and inject the depmod snippet at #DEBHELPER#.
	sed "s/@KVER@/$$BASE/g" debian/linux-image.postinst.in > debian/$$CHANGELOG_PKG.postinst; \
	chmod 755 debian/$$CHANGELOG_PKG.postinst; \
	\
	# Copy static maintainer scripts (preinst, postrm, prerm) to versioned names.
	for script in preinst postrm prerm; do \
		if [ -f debian/linux-image.$$script ]; then \
			cp debian/linux-image.$$script debian/$$CHANGELOG_PKG.$$script; \
			chmod 755 debian/$$CHANGELOG_PKG.$$script; \
		fi; \
	done; \
	\
	# dh_installmodules finds debian/<pkgname>.postinst and injects depmod at #DEBHELPER#
	dh_installmodules; \
	\
	# dh_installdeb moves the scripts into debian/<pkg>/DEBIAN/
	dh_installdeb

override_dh_auto_test:
	@echo "Skipping dh_auto_test (no kernel test suite)."

override_dh_auto_clean:
	# Only clean the objdir if one is used; never nuke the source tree.
ifneq ($(BUILD_OBJ),)
	$(MAKE) $(KBUILD_O_ARG) clean
endif
	# Our cache file
	rm -f $(KREL_FILE)

override_dh_gencontrol:
	@mkdir -p $(dir $(KREL_FILE)) debian
	# Ensure BASE (uname -r) is available/cached
	if [ ! -s "$(KREL_FILE)" ]; then \
		BASE="$$( $(MAKE) $(KBUILD_O_ARG) ARCH=$(ARCH) -s kernelrelease )"; \
		printf "%s\n" "$$BASE" > "$(KREL_FILE)"; \
	else \
		BASE="$$(cat "$(KREL_FILE)")"; \
	fi; \
	echo "dh_gencontrol: Version=1-1"; \
	# Run dh_gencontrol with simple version (package name already has kernel version)
	dh_gencontrol -- -v"1-1"
