#!/usr/bin/make -f
.ONESHELL:
SHELL := /bin/bash
.SHELLFLAGS := -e -o pipefail -c

# Include dpkg package info only after 'prepare' has generated debian/changelog.
# If the file still contains the @PKGVER@ placeholder, skip the include to
# avoid confusing dpkg-parsechangelog warnings.
ifneq ($(wildcard debian/changelog),)
ifeq ($(shell grep -qF '@PKGVER@' debian/changelog 2>/dev/null && echo template || echo ready),ready)
include /usr/share/dpkg/pkg-info.mk
export DEB_VERSION
endif
endif

export DH_VERBOSE ?= 1
export ARCH = arm64

# Optional out-of-tree build directory (honor either O or KBUILD_OUTPUT).
BUILD_OBJ ?= $(or $(O),$(KBUILD_OUTPUT))

# Make argument that is empty when BUILD_OBJ is empty.
KBUILD_O_ARG := $(if $(BUILD_OBJ),O=$(BUILD_OBJ),)

# Parallel jobs (override with DEB_BUILD_OPTIONS=parallel=N if desired).
PARALLEL ?= $(shell nproc)

# objcopy for debug symbol extraction (cross-compile aware).
OBJCOPY ?= $(shell which aarch64-linux-gnu-objcopy 2>/dev/null || which objcopy 2>/dev/null || echo objcopy)

# File that caches the kernelrelease (uname -r) written by override_dh_auto_build.
KREL_FILE := debian/kernel.release

%:
	dh $@ --buildsystem=makefile

# ---------------------------------------------------------------------------
# prepare: generate debian/control and debian/changelog from *.in templates.
#
# Must be called before dpkg-buildpackage / sbuild since those tools read
# debian/control before invoking any debian/rules targets.
#
# Inputs (make variables):
#   LOCALVERSION   Suffix appended to the base kernel version, e.g. -qcom-next-20260722.
#                  Required unless KVER is given explicitly.
#   KVER           Full kernelrelease string (uname -r). Overrides LOCALVERSION.
#   KVER_EXTRA     Optional extra suffix appended after LOCALVERSION, e.g. -ci42.
#   DISTRO         Target Debian/Ubuntu suite (default: unstable).
#   SRCPKG         Source package name (default: linux-qcom-next).
#   BINPKG         Binary metapackage name (default: linux-image-qcom-next).
#   DEBIAN_REVISION  Debian revision component of the package version (default: 0qcom1).
#
# Outputs (generated files, all listed in debian/clean):
#   debian/control       Substituted from debian/control.in
#   debian/changelog     Substituted from debian/changelog.in
#   debian/localversion  Plain file containing the LOCALVERSION suffix (e.g. -qcom-next-20260722).
#                        Read by override_dh_auto_build to pass LOCALVERSION= to make.
#   debian/pkgversion    Plain file containing the full Debian package version
#                        (e.g. 7.2.0-rc3+20260722-0qcom1).
#                        Read by override_dh_gencontrol.
# ---------------------------------------------------------------------------
KVER_EXTRA       ?=
DISTRO           ?= unstable
SRCPKG           ?= linux-qcom-next
BINPKG           ?= linux-image-qcom-next
DEBIAN_REVISION  ?= 0qcom1

.PHONY: prepare
prepare:
	@set -e; \
	\
	# ── Resolve KVER (uname -r) ──────────────────────────────────────────────
	if [ -n "$(KVER)" ]; then \
		KVER_RESOLVED="$(KVER)"; \
	else \
		[ -n "$(LOCALVERSION)" ] || { \
			echo "ERROR: LOCALVERSION is required when KVER is not set."; \
			echo "       Pass LOCALVERSION=<suffix> (e.g. LOCALVERSION=-qcom-next-20260722)"; \
			echo "       or KVER=<full-kernelrelease> (e.g. KVER=7.2.0-rc3-qcom-next-20260722)"; \
			exit 1; \
		}; \
		echo "Reading base kernel version from kernel Makefile..."; \
		VER=$$(grep '^VERSION = ' Makefile | awk '{print $$3}'); \
		PATCH=$$(grep '^PATCHLEVEL = ' Makefile | awk '{print $$3}'); \
		SUB=$$(grep '^SUBLEVEL = ' Makefile | awk '{print $$3}'); \
		EXTRA=$$(grep '^EXTRAVERSION = ' Makefile | awk '{print $$3}' || true); \
		TREE_LOCALVER=$$(cat localversion* 2>/dev/null | tr -d '\n' || true); \
		BASE_KVER="$${VER}.$${PATCH}.$${SUB}$${EXTRA}$${TREE_LOCALVER}"; \
		KVER_RESOLVED="$${BASE_KVER}$(LOCALVERSION)"; \
		echo "Resolved KVER=$$KVER_RESOLVED (base=$$BASE_KVER, LOCALVERSION=$(LOCALVERSION))"; \
	fi; \
	if [ -n "$(KVER_EXTRA)" ]; then \
		KVER_RESOLVED="$${KVER_RESOLVED}$(KVER_EXTRA)"; \
		echo "Appended KVER_EXTRA=$(KVER_EXTRA) -> KVER=$$KVER_RESOLVED"; \
	fi; \
	\
	# ── Derive package version from KVER ─────────────────────────────────────
	# Package version format: <base_kver>+<date>-<debian_revision>
	# where base_kver = kernel version without the LOCALVERSION suffix,
	# and date = the 8-digit date component of LOCALVERSION (if present).
	# For branch-tip builds (no date in LOCALVERSION), version = <base_kver>-<debian_revision>.
	#
	# Extract base_kver: read directly from kernel Makefile (same as above but
	# without LOCALVERSION appended), so it is always the pure kernel version.
	VER=$$(grep '^VERSION = ' Makefile | awk '{print $$3}'); \
	PATCH=$$(grep '^PATCHLEVEL = ' Makefile | awk '{print $$3}'); \
	SUB=$$(grep '^SUBLEVEL = ' Makefile | awk '{print $$3}'); \
	EXTRA=$$(grep '^EXTRAVERSION = ' Makefile | awk '{print $$3}' || true); \
	TREE_LOCALVER=$$(cat localversion* 2>/dev/null | tr -d '\n' || true); \
	BASE_KVER_CLEAN="$${VER}.$${PATCH}.$${SUB}$${EXTRA}$${TREE_LOCALVER}"; \
	\
	# Extract date from LOCALVERSION: last dash-delimited component if 8 digits.
	DATE_PART=$$(echo "$(LOCALVERSION)" | grep -oE '[0-9]{8}$$' || true); \
	if [ -n "$$DATE_PART" ]; then \
		UPSTREAM_VER="$${BASE_KVER_CLEAN}+$${DATE_PART}"; \
	else \
		UPSTREAM_VER="$${BASE_KVER_CLEAN}"; \
	fi; \
	PKG_VERSION="$${UPSTREAM_VER}-$(DEBIAN_REVISION)"; \
	echo "Package version: $$PKG_VERSION"; \
	\
	# ── Derive HDRPKG from BINPKG ─────────────────────────────────────────────
	HDRPKG=$$(echo "$(BINPKG)" | sed 's/^linux-image-/linux-headers-/'); \
	\
	# ── Substitute templates ──────────────────────────────────────────────────
	sed \
		-e "s|@SRCPKG@|$(SRCPKG)|g" \
		-e "s|@BINPKG@|$(BINPKG)|g" \
		-e "s|@HDRPKG@|$$HDRPKG|g" \
		-e "s|@KVER@|$$KVER_RESOLVED|g" \
		-e "s|@PKGVER@|$$PKG_VERSION|g" \
		debian/control.in > debian/control; \
	sed \
		-e "s|@SRCPKG@|$(SRCPKG)|g" \
		-e "s|@PKGVER@|$$PKG_VERSION|g" \
		-e "s|@DISTRO@|$(DISTRO)|g" \
		-e "s|@KVER@|$$KVER_RESOLVED|g" \
		-e "s|@GITCLONE@||g" \
		-e "s|@BRANCH@||g" \
		debian/changelog.in > debian/changelog; \
	\
	# ── Write runtime state files ─────────────────────────────────────────────
	# debian/localversion: the LOCALVERSION suffix, read by override_dh_auto_build.
	# Contains only the suffix (e.g. -qcom-next-20260722), not the full KVER.
	printf '%s\n' "$(LOCALVERSION)" > debian/localversion; \
	\
	# debian/pkgversion: the full Debian package version, read by override_dh_gencontrol.
	printf '%s\n' "$$PKG_VERSION" > debian/pkgversion; \
	\
	echo "Generated debian/control, debian/changelog, debian/localversion, debian/pkgversion"; \
	echo "  SRCPKG=$(SRCPKG)  BINPKG=$(BINPKG)  HDRPKG=$$HDRPKG"; \
	echo "  KVER=$$KVER_RESOLVED  PKGVER=$$PKG_VERSION  DISTRO=$(DISTRO)"

override_dh_auto_configure:
	# ---------------------------------------------------------------------------
	# Config build order:
	#   1. ARM64 base defconfig
	#   2. Disable CONFIG_LOCALVERSION_AUTO (must happen before any merges)
	#   3. Config fragments applied in a single unified pipeline:
	#        a. arch/arm64/configs/qcom.config   (kernel-source, always applied if present)
	#        b. arch/arm64/configs/prune.config  (kernel-source, always applied if present)
	#        c. debian/config/*.config            (packaging fragments, sorted order)
	#           Populated by prepare-source.sh --kernel-config from debian/config-available/.
	#           Empty by default — no fragments applied unless explicitly activated.
	#      All fragments: append to .config + make olddefconfig.
	#   4. Re-check CONFIG_LOCALVERSION_AUTO (merges may re-enable it)
	#   5. arch/arm64/configs/debug.config — only when DEB_BUILD_PROFILES=debug
	# ---------------------------------------------------------------------------

	# Step 1: Base defconfig
	$(MAKE) $(KBUILD_O_ARG) ARCH=$(ARCH) defconfig

	# Step 2: Disable CONFIG_LOCALVERSION_AUTO to prevent git hash in version.
	@CONFIG_FILE="$(if $(BUILD_OBJ),$(BUILD_OBJ)/).config"; \
	if [ -f "$$CONFIG_FILE" ]; then \
		echo "Disabling CONFIG_LOCALVERSION_AUTO in $$CONFIG_FILE"; \
		sed -i '/^CONFIG_LOCALVERSION_AUTO/d' "$$CONFIG_FILE"; \
		echo "# CONFIG_LOCALVERSION_AUTO is not set" >> "$$CONFIG_FILE"; \
		echo "CONFIG_LOCALVERSION_AUTO disabled"; \
	else \
		echo "ERROR: .config not found at $$CONFIG_FILE"; \
		exit 1; \
	fi

	# Step 3: Unified config fragment pipeline.
	@CONFIG_FILE="$(if $(BUILD_OBJ),$(BUILD_OBJ)/).config"; \
	FRAGMENTS=""; \
	if [ -f arch/arm64/configs/qcom.config ]; then \
		echo "Found kernel-source fragment: arch/arm64/configs/qcom.config"; \
		FRAGMENTS="arch/arm64/configs/qcom.config"; \
	else \
		echo "Note: arch/arm64/configs/qcom.config not found (not a qcom-next tree?)"; \
	fi; \
	if [ -f arch/arm64/configs/prune.config ]; then \
		echo "Found kernel-source fragment: arch/arm64/configs/prune.config"; \
		FRAGMENTS="$$FRAGMENTS arch/arm64/configs/prune.config"; \
	else \
		echo "Note: arch/arm64/configs/prune.config not found (skipping)"; \
	fi; \
	if [ -d debian/config ] && ls debian/config/*.config >/dev/null 2>&1; then \
		for f in $$(ls debian/config/*.config | sort); do \
			echo "Found packaging fragment: $$f"; \
			FRAGMENTS="$$FRAGMENTS $$f"; \
		done; \
	else \
		echo "Note: no packaging fragments in debian/config/ (none activated via --kernel-config)"; \
	fi; \
	if [ -n "$$FRAGMENTS" ]; then \
		for frag in $$FRAGMENTS; do \
			echo "Applying config fragment: $$frag"; \
			cat "$$frag" >> "$$CONFIG_FILE"; \
		done; \
		echo "Running olddefconfig to resolve all fragment conflicts..."; \
		$(MAKE) $(KBUILD_O_ARG) ARCH=$(ARCH) olddefconfig; \
	else \
		echo "No config fragments to apply (defconfig only)"; \
	fi

	# Step 4: Re-check CONFIG_LOCALVERSION_AUTO — merges may have re-enabled it.
	@CONFIG_FILE="$(if $(BUILD_OBJ),$(BUILD_OBJ)/).config"; \
	if grep -q "^CONFIG_LOCALVERSION_AUTO=y" "$$CONFIG_FILE" 2>/dev/null; then \
		echo "Re-disabling CONFIG_LOCALVERSION_AUTO (was re-enabled by a config merge)"; \
		sed -i '/^CONFIG_LOCALVERSION_AUTO/d' "$$CONFIG_FILE"; \
		echo "# CONFIG_LOCALVERSION_AUTO is not set" >> "$$CONFIG_FILE"; \
	fi

	# Step 5: Merge debug.config if debug build profile is active.
	@if echo "$(DEB_BUILD_PROFILES)" | grep -qw "debug"; then \
		if [ -f arch/arm64/configs/debug.config ]; then \
			echo "Debug profile active: merging arch/arm64/configs/debug.config..."; \
			$(MAKE) $(KBUILD_O_ARG) ARCH=$(ARCH) debug.config; \
		else \
			echo "Warning: debug profile requested but arch/arm64/configs/debug.config not found"; \
		fi; \
	fi

override_dh_auto_build:
	# Read LOCALVERSION from debian/localversion (written by 'prepare' target).
	# This avoids the fragile back-derivation from the source package name that
	# broke when the source package name no longer encodes the kernel version.
	@[ -f debian/localversion ] || { \
		echo "ERROR: debian/localversion not found."; \
		echo "       Run 'make -f debian/rules prepare LOCALVERSION=...' first."; \
		exit 1; \
	}; \
	LOCALVER_SUFFIX=$$(cat debian/localversion); \
	echo "Building with LOCALVERSION=$$LOCALVER_SUFFIX"; \
	$(MAKE) $(KBUILD_O_ARG) ARCH=$(ARCH) LOCALVERSION=$$LOCALVER_SUFFIX -j$(PARALLEL) Image; \
	$(MAKE) $(KBUILD_O_ARG) ARCH=$(ARCH) LOCALVERSION=$$LOCALVER_SUFFIX -j$(PARALLEL) modules; \
	$(MAKE) $(KBUILD_O_ARG) ARCH=$(ARCH) LOCALVERSION=$$LOCALVER_SUFFIX -j$(PARALLEL) dtbs || true; \
	mkdir -p $(dir $(KREL_FILE)); \
	KREL=$$( $(MAKE) $(KBUILD_O_ARG) ARCH=$(ARCH) LOCALVERSION=$$LOCALVER_SUFFIX -s kernelrelease 2>&1 | grep -E '^[0-9]+\.' | head -n1 ); \
	printf "%s\n" "$$KREL" > "$(KREL_FILE)"; \
	echo "Kernel release (uname -r): $$KREL"

override_dh_auto_install:
	# Derive all binary package staging directory names from BASE (uname -r),
	# not from the source package name. The source package name (linux-qcom-next)
	# no longer encodes the kernel version, so it cannot be used for derivation.
	@BASE=$$(cat $(KREL_FILE)); \
	echo "Installing for kernel release: $$BASE"; \
	PKG=debian/linux-image-$$BASE; \
	HDR_PKG=debian/linux-headers-$$BASE; \
	DBG_PKG=debian/linux-image-$$BASE-dbg; \
	\
	# Resolve object dir (if any)
	OBJ_DIR="$(BUILD_OBJ)"; \
	IMG_DIR="arch/arm64/boot"; \
	DTB_ROOT="arch/arm64/boot/dts/"; \
	if [ -n "$$OBJ_DIR" ]; then \
		IMG_DIR="$$OBJ_DIR/$$IMG_DIR"; \
		DTB_ROOT="$$OBJ_DIR/$$DTB_ROOT"; \
	fi; \
	\
	# Pick the first available kernel image: Image, Image.gz, or Image.lz4
	IMG_PATH=""; \
	for cand in "$$IMG_DIR/Image" "$$IMG_DIR/Image.gz" "$$IMG_DIR/Image.lz4"; do \
		if [ -f "$$cand" ]; then IMG_PATH="$$cand"; break; fi; \
	done; \
	[ -n "$$IMG_PATH" ] || { echo "ERROR: No kernel image found under $$IMG_DIR (tried Image, Image.gz, Image.lz4)"; exit 1; }; \
	[ -d "$$DTB_ROOT" ] || { echo "ERROR: Missing DTB root at $$DTB_ROOT"; exit 1; }; \
	\
	# Locate the active .config (objdir-aware)
	CFG_PATH=".config"; \
	[ -n "$$OBJ_DIR" ] && CFG_PATH="$$OBJ_DIR/.config"; \
	[ -f "$$CFG_PATH" ] || { echo "ERROR: Missing .config at $$CFG_PATH"; exit 1; }; \
	\
	# /boot artifacts
	mkdir -p "$$PKG/boot"; \
	cp -a -T "$$IMG_PATH" "$$PKG/boot/vmlinuz-$$BASE"; \
	cp -a -T "$$CFG_PATH" "$$PKG/boot/config-$$BASE"; \
	\
	# Modules (stripped)
	$(MAKE) $(KBUILD_O_ARG) ARCH=$(ARCH) modules_install \
		INSTALL_MOD_PATH=$$PKG INSTALL_MOD_STRIP=1; \
	\
	# Fix build/source symlinks to point at the installed headers package.
	rm -f $$PKG/lib/modules/$$BASE/build; \
	rm -f $$PKG/lib/modules/$$BASE/source; \
	ln -sf /usr/src/linux-headers-$$BASE $$PKG/lib/modules/$$BASE/build; \
	ln -sf /usr/src/linux-headers-$$BASE $$PKG/lib/modules/$$BASE/source; \
	\
	# DTBs: standard Debian location /usr/lib/linux-image-<BASE>/
	mkdir -p $$PKG/usr/lib/linux-image-$$BASE; \
	rsync -a --prune-empty-dirs \
	      --include='*/' --include='*.dtb' --include='*.dtbo' --exclude='*' \
	      "$$DTB_ROOT" $$PKG/usr/lib/linux-image-$$BASE/; \
	\
	# Ubuntu flash-kernel compatibility symlink:
	#   /usr/lib/firmware/<BASE>/device-tree -> ../../linux-image-<BASE>
	# Relative symlink so it resolves correctly on both classic and usrmerge systems.
	mkdir -p $$PKG/usr/lib/firmware/$$BASE; \
	ln -sfT ../../linux-image-$$BASE $$PKG/usr/lib/firmware/$$BASE/device-tree; \
	\
	# Kernel headers for linux-headers-<BASE> package.
	# Pass 1: source-tree files (Makefile, include/, scripts/, arch/arm64/ headers).
	# Pass 2: build-directory generated files (overlay on Pass 1).
	# Note: make headers_install (UAPI) is intentionally NOT run — it corrupts
	# kernel-internal headers (bitsperlong.h) and breaks DKMS/out-of-tree builds.
	HDRDIR="$$HDR_PKG/usr/src/linux-headers-$$BASE"; \
	echo "Installing kernel headers to $$HDRDIR"; \
	mkdir -p "$$HDRDIR"; \
	cp -a Makefile "$$HDRDIR/"; \
	cp -a include "$$HDRDIR/"; \
	cp -a scripts "$$HDRDIR/"; \
	mkdir -p "$$HDRDIR/arch/arm64"; \
	find arch/arm64 -maxdepth 1 -name 'Makefile*' \
	    -exec cp -a {} "$$HDRDIR/arch/arm64/" \; 2>/dev/null || true; \
	[ -d arch/arm64/include ] && cp -a arch/arm64/include "$$HDRDIR/arch/arm64/"; \
	if [ -n "$$OBJ_DIR" ]; then \
		[ -d "$$OBJ_DIR/include/generated" ] && \
		    cp -a "$$OBJ_DIR/include/generated" "$$HDRDIR/include/"; \
		if [ -d "$$OBJ_DIR/arch/arm64/include/generated" ]; then \
		    mkdir -p "$$HDRDIR/arch/arm64/include"; \
		    cp -a "$$OBJ_DIR/arch/arm64/include/generated" "$$HDRDIR/arch/arm64/include/"; \
		fi; \
		[ -d "$$OBJ_DIR/scripts" ] && cp -a "$$OBJ_DIR/scripts/." "$$HDRDIR/scripts/"; \
		cp -a "$$OBJ_DIR/Module.symvers" "$$HDRDIR/" 2>/dev/null || true; \
		cp -a "$$OBJ_DIR/.config" "$$HDRDIR/"; \
	else \
		cp -a Module.symvers "$$HDRDIR/" 2>/dev/null || true; \
		cp -a .config "$$HDRDIR/"; \
	fi; \
	mkdir -p "$$HDRDIR/arch/arm64/kernel"; \
	MODULE_LDS="arch/arm64/kernel/module.lds"; \
	[ -n "$$OBJ_DIR" ] && MODULE_LDS="$$OBJ_DIR/arch/arm64/kernel/module.lds"; \
	cp -a "$$MODULE_LDS" "$$HDRDIR/arch/arm64/kernel/" 2>/dev/null || true; \
	\
	# Debug symbols for linux-image-<BASE>-dbg package.
	echo "Installing debug symbols to $$DBG_PKG"; \
	MODULES_ORDER="modules.order"; \
	[ -n "$$OBJ_DIR" ] && MODULES_ORDER="$$OBJ_DIR/modules.order"; \
	if [ -f "$$MODULES_ORDER" ]; then \
		while IFS= read -r mod; do \
			mod="$${mod%.o}.ko"; \
			src_mod="$$mod"; \
			[ -n "$$OBJ_DIR" ] && src_mod="$$OBJ_DIR/$$mod"; \
			[ -f "$$src_mod" ] || continue; \
			dbg="$$DBG_PKG/usr/lib/debug/lib/modules/$$BASE/$$mod"; \
			mkdir -p "$${dbg%/*}"; \
			$(OBJCOPY) --only-keep-debug "$$src_mod" "$$dbg" 2>/dev/null || \
				cp -a "$$src_mod" "$$dbg"; \
		done < "$$MODULES_ORDER"; \
	else \
		echo "Warning: modules.order not found — skipping per-module debug symbol extraction"; \
	fi; \
	VMLINUX_PATH="vmlinux"; \
	[ -n "$$OBJ_DIR" ] && VMLINUX_PATH="$$OBJ_DIR/vmlinux"; \
	if [ -f "$$VMLINUX_PATH" ]; then \
		mkdir -p $$DBG_PKG/usr/lib/debug/lib/modules/$$BASE; \
		cp -a $$VMLINUX_PATH $$DBG_PKG/usr/lib/debug/lib/modules/$$BASE/vmlinux; \
		mkdir -p $$DBG_PKG/usr/lib/debug/boot; \
		ln -sf ../lib/modules/$$BASE/vmlinux \
		       $$DBG_PKG/usr/lib/debug/boot/vmlinux-$$BASE; \
		ln -sf lib/modules/$$BASE/vmlinux \
		       $$DBG_PKG/usr/lib/debug/vmlinux-$$BASE; \
	else \
		echo "Warning: vmlinux not found at $$VMLINUX_PATH — debug package will not contain vmlinux"; \
	fi

# Skip automatic dh_installmodules — called manually in override_dh_installdeb.
override_dh_installmodules:
	@echo "Skipping automatic dh_installmodules (called manually in override_dh_installdeb)"

override_dh_installdeb:
	# Generate versioned maintainer scripts from templates using BASE (uname -r).
	# The binary package name is linux-image-<BASE>, derived from kernel.release.
	# dh_installmodules injects the depmod snippet at #DEBHELPER# in the postinst.
	@BASE=$$(cat $(KREL_FILE)); \
	INST_PKG="linux-image-$$BASE"; \
	\
	# Generate debian/linux-image-<BASE>.postinst from template.
	sed "s/@KVER@/$$BASE/g" debian/linux-image.postinst.in > debian/$$INST_PKG.postinst; \
	chmod 755 debian/$$INST_PKG.postinst; \
	\
	# Copy static maintainer scripts to versioned names.
	for script in preinst postrm prerm; do \
		if [ -f debian/linux-image.$$script ]; then \
			cp debian/linux-image.$$script debian/$$INST_PKG.$$script; \
			chmod 755 debian/$$INST_PKG.$$script; \
		fi; \
	done; \
	\
	dh_installmodules; \
	dh_installdeb

override_dh_auto_test:
	@echo "Skipping dh_auto_test (no kernel test suite)."

override_dh_auto_clean:
	# Only clean the objdir if one is used; never nuke the source tree.
ifneq ($(BUILD_OBJ),)
	$(MAKE) $(KBUILD_O_ARG) clean
endif
	rm -f $(KREL_FILE)

override_dh_gencontrol:
	# Read the package version from debian/pkgversion (written by 'prepare' target).
	# This replaces the old hardcoded -v"1-1" which was only valid when the kernel
	# version was encoded entirely in the package name.
	@[ -f debian/pkgversion ] || { \
		echo "ERROR: debian/pkgversion not found."; \
		echo "       Run 'make -f debian/rules prepare ...' first."; \
		exit 1; \
	}; \
	PKG_VERSION=$$(cat debian/pkgversion); \
	echo "dh_gencontrol: Version=$$PKG_VERSION"; \
	dh_gencontrol -- -v"$$PKG_VERSION"
