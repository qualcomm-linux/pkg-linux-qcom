#!/usr/bin/make -f
.ONESHELL:
SHELL := /bin/bash
.SHELLFLAGS := -e -o pipefail -c

include /usr/share/dpkg/pkg-info.mk

export DEB_VERSION

export DH_VERBOSE ?= 1
export ARCH = arm64

# Optional out-of-tree build directory (honor either O or KBUILD_OUTPUT)
# If set, we'll pass O=<dir> to make and read artifacts from that objdir.
BUILD_OBJ ?= $(or $(O),$(KBUILD_OUTPUT))

# Make argument that is empty when BUILD_OBJ is empty (so we don't pass a dangling "O=")
KBUILD_O_ARG := $(if $(BUILD_OBJ),O=$(BUILD_OBJ),)

# Parallel jobs (override with DEB_BUILD_OPTIONS=parallel=N if desired)
PARALLEL ?= $(shell nproc)

# Optional build id for Debian version tagging (not runtime paths)
# Usage: BUILD_ID=19085636185-1 dpkg-buildpackage -us -uc -b
BUILD_ID ?=

# File that caches the kernelrelease (BASE, i.e., uname -r)
KREL_FILE := debian/kernel.release

# Helper: compute Debian version like 1.0+<BASE>[-<BUILD_ID>]
define mk_pkg_version
	@BASE=$$(cat $(KREL_FILE)); \
	V="1.0+$$BASE"; \
	if [ -n "$(BUILD_ID)" ]; then V="$$V-$(BUILD_ID)"; fi; \
	echo $$V
endef

# Helper: inject substitution vars and package version into control
define gencontrol_vars
	@BASE=$$(cat $(KREL_FILE)); \
	EXTRA=""; \
	[ -n "$(BUILD_ID)" ] && EXTRA="$$EXTRA -Vqcom:BuildId=$(BUILD_ID)"; \
	dh_gencontrol -Vqcom:BaseKrel="$$BASE" $$EXTRA -v "$$($(call mk_pkg_version))"
endef

%:
	dh $@ --buildsystem=makefile

override_dh_auto_configure:
	# Base defconfig (+ vendor fragment if present)
	[ -f arch/arm64/configs/qcom.config ] && \
		$(MAKE) $(KBUILD_O_ARG) ARCH=$(ARCH) defconfig qcom.config || \
		$(MAKE) $(KBUILD_O_ARG) ARCH=$(ARCH) defconfig

override_dh_auto_build:
	# Build kernel, modules, DTBs, and ensure a bootable image target is made
	$(MAKE) $(KBUILD_O_ARG) ARCH=$(ARCH) -j$(PARALLEL) Image
	$(MAKE) $(KBUILD_O_ARG) ARCH=$(ARCH) -j$(PARALLEL) modules
	$(MAKE) $(KBUILD_O_ARG) ARCH=$(ARCH) -j$(PARALLEL) dtbs || true
	# Cache BASE (uname -r) for later steps — filter out make's Entering/Leaving noise
	@mkdir -p $(dir $(KREL_FILE)); \
	KREL=$$( $(MAKE) $(KBUILD_O_ARG) ARCH=$(ARCH) -s kernelrelease 2>&1 | grep -E '^[0-9]+\.' | head -n1 ); \
	printf "%s\n" "$$KREL" > "$(KREL_FILE)"; \
	echo "Detected BASE kernel release: $$KREL"

override_dh_auto_install:
	@BASE=$$(cat $(KREL_FILE)); \
	echo "Installing for BASE kernel release: $$BASE"; \
	PKG=debian/qcom-linux-kernel; \
	\
	# Resolve object dir (if any)
	OBJ_DIR="$(BUILD_OBJ)"; \
	IMG_DIR="arch/arm64/boot"; \
	DTB_ROOT="arch/arm64/boot/dts/"; \
	if [ -n "$$OBJ_DIR" ]; then \
		IMG_DIR="$$OBJ_DIR/$$IMG_DIR"; \
		DTB_ROOT="$$OBJ_DIR/$$DTB_ROOT"; \
	fi; \
	\
	# Pick the first available kernel image: Image, Image.gz, or Image.lz4
	IMG_PATH=""; \
	for cand in "$$IMG_DIR/Image" "$$IMG_DIR/Image.gz" "$$IMG_DIR/Image.lz4"; do \
		if [ -f "$$cand" ]; then IMG_PATH="$$cand"; break; fi; \
	done; \
	[ -n "$$IMG_PATH" ] || { echo "ERROR: No kernel image found under $$IMG_DIR (tried Image, Image.gz, Image.lz4)"; exit 1; }; \
	[ -d "$$DTB_ROOT" ] || { echo "ERROR: Missing DTB root at $$DTB_ROOT"; exit 1; }; \
	\
	# Locate the active .config (objdir-aware)
	CFG_PATH=".config"; \
	[ -n "$$OBJ_DIR" ] && CFG_PATH="$$OBJ_DIR/.config"; \
	[ -f "$$CFG_PATH" ] || { echo "ERROR: Missing .config at $$CFG_PATH"; exit 1; }; \
	\
	# /boot artifacts (always install as vmlinuz-<BASE>)
	# (avoid 'install -D' parsing quirks by creating dirs and copying explicitly)
	mkdir -p "$$PKG/boot"; \
	cp -a -T "$$IMG_PATH" "$$PKG/boot/vmlinuz-$$BASE"; \
	cp -a -T "$$CFG_PATH" "$$PKG/boot/config-$$BASE"; \
	\
	# Modules (strip like your original packaging script)
	$(MAKE) $(KBUILD_O_ARG) ARCH=$(ARCH) modules_install \
		INSTALL_MOD_PATH=$$PKG INSTALL_MOD_STRIP=1; \
	\
	# ALL DTBs recursively (preserve vendor subdirs), only *.dtb
	mkdir -p $$PKG/lib/firmware/$$BASE/device-tree; \
	rsync -a --prune-empty-dirs \
	      --include='*/' --include='*.dtb' --exclude='*' \
	      "$$DTB_ROOT" $$PKG/lib/firmware/$$BASE/device-tree/

override_dh_auto_test:
	@echo "Skipping dh_auto_test (no kernel test suite)."

override_dh_auto_clean:
	# Only clean the objdir if one is used; never nuke the source tree.
ifneq ($(BUILD_OBJ),)
	$(MAKE) $(KBUILD_O_ARG) clean
endif
	# Our cache file
	rm -f $(KREL_FILE)

override_dh_gencontrol:
	@mkdir -p $(dir $(KREL_FILE)) debian
	# 1) Ensure BASE (uname -r) is available/cached
	if [ ! -s "$(KREL_FILE)" ]; then \
		BASE="$$( $(MAKE) $(KBUILD_O_ARG) ARCH=$(ARCH) -s kernelrelease )"; \
		printf "%s\n" "$$BASE" > "$(KREL_FILE)"; \
	else \
		BASE="$$(cat "$(KREL_FILE)")"; \
	fi; \
	# 2) Compose binary version: <SRC_VER>+<BASE>[-<BUILD_ID>]
	V="$(DEB_VERSION)+$$BASE"; \
	if [ -n "$(BUILD_ID)" ]; then V="$$V-$(BUILD_ID)"; fi; \
	echo "$$V" > debian/pkg.version; \
	echo "dh_gencontrol: Version=$$V (SRC_VER=$$SRC_VER, BASE=$$BASE, BUILD_ID=$(BUILD_ID))"; \
	# 4) Run dh_gencontrol with our substvars
	dh_gencontrol -Vqcom:BaseKrel="$$BASE" -Vqcom:BuildId="$(BUILD_ID)"; \
	# 5) Force the Version field in the generated control file
	sed -i -E "s/^Version: .*/Version: $$V/" debian/qcom-linux-kernel/DEBIAN/control

override_dh_builddeb:
	@# Reuse the composed version and fix debian/files to match the actual .deb name
	V="$$(cat debian/pkg.version)"; \
	ARCH="$$(dpkg-architecture -qDEB_HOST_ARCH)"; \
	echo "dh_builddeb: expecting qcom-linux-kernel_$${V}_$${ARCH}.deb"; \
	dh_builddeb; \
	if [ -f debian/files ]; then \
	  sed -i -E "s@(qcom-linux-kernel_)[^_]+(_$${ARCH}\.deb)@\\1$${V}\\2@" debian/files; \
	fi

